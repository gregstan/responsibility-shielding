ll,"AutoScoringCategory":null}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"false","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":"None","SurveyTermination":"Redirect","Header":"","Footer":"","ProgressBarDisplay":"VerboseText","PartialData":"+1 day","ValidationMessage":null,"PreviousButton":"","NextButton":"","SurveyTitle":"Qualtrics Survey | Qualtrics Experience Management","SkinLibrary":"umich","SkinType":"component","Skin":{"brandingId":"3019387420","templateId":"*simple","overrides":{"colors":{"primary":"#000000"},"background":{"color":"#000000"}}},"NewScoring":1,"SurveyMetaDescription":"The most powerful, simple and trusted way to gather experience data. Start your journey to experience management and try a free account today.","EOSMessage":null,"ShowExportTags":"false","CollectGeoLocation":"false","PasswordProtection":"No","AnonymizeResponse":"No","RefererCheck":"No","BallotBoxStuffingPreventionBehavior":null,"BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"RecaptchaV3":"true","ConfirmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessageLibrary":null,"ResponseSummary":"No","EOSMessageLibrary":null,"EOSRedirectURL":"https:\/\/umichpsych.sona-systems.com\/webstudy_credit.aspx?experiment_id=3757&credit_token=8cbc241ff9da4a79850378db183b5f9f&survey_code=${e:\/\/Field\/id}","EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":"DefaultMessage","PartialDeletion":null,"PartialDataCloseAfter":"LastActivity","InactiveMessageLibrary":null,"InactiveMessage":null,"AvailableLanguages":{"EN":[]},"SurveyName":"Responsibility Shielding","ProtectSelectionIds":true}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":"UNIVERSITY OF MICHIGAN CONSENT TO BE PART OF THIS STUDY Study Title: Moral Judgments Study Creato...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>UNIVERSITY OF MICHIGAN\nCONSENT TO BE PART OF THIS STUDY<\/b><br><br><b>Study Title:<\/b> Moral Judgments\nStudy Creator: Gregory Stanley, Ph.D. Candidate, University of Michigan<br><b>Faculty Advisor:<\/b> Jun Zhang, Professor of Psychology, University of Michigan<br><br>Thank you for your interest in participating in this experiment. Please read this entire form before deciding whether to take part.<br><br><b>KEY INFORMATION<\/b><br>This study examines how people make judgments about moral responsibility and punishment in short hypothetical scenarios.<br><b>&nbsp;\u2022\tWhat you will do:<\/b> Read short scenarios, answer questions about blame\/wrongness\/punishment, complete a brief memory task, and answer brief questionnaires.<br><b>&nbsp;\u2022\tDuration:<\/b> Approximately 30 minutes of continuous participation.<br><b>&nbsp;\u2022\tCompensation\/Credit:<\/b> 0.5 SONA credit for completion.<br><b>&nbsp;\u2022\tRisks:<\/b> Some scenarios describe serious injury and may be unpleasant or upsetting. There are no other foreseeable risks beyond everyday life.<br><b>&nbsp;\u2022\tData Security:<\/b> Responses are collected through Qualtrics and stored securely.<br><b>&nbsp;\u2022\tStopping:<\/b> You may stop at any time without penalty, but completion is required for SONA credit.<br>&nbsp;<b>\u2022\t18+ Years Old:<\/b> You must be 18 years of age or older to participate.<br><br><b>PURPOSE OF THIS STUDY<\/b><br>The purpose of this study is to understand the nuances of how people attribute moral responsibility and punishment.<br><br><b>WHAT WILL HAPPEN TO ME IN THIS STUDY?<\/b><br><b>&nbsp;\u2022\tOnline Participation: <\/b>This study is completed online via Qualtrics.<br><b>&nbsp;\u2022\tScenarios + Ratings: <\/b>You will read several short scenarios and rate judgments such as blameworthiness, wrongness, and punishment.<br><b>&nbsp;\u2022\tMemory Task: <\/b>You will be asked to remember a number briefly while answering some questions.<br><b>&nbsp;\u2022\tQuestionnaires: <\/b>You will answer short questionnaires about reasoning style and social attitudes, plus basic demographics.<br><b>&nbsp;\u2022\tDebriefing: <\/b>You will receive a debriefing form at the end of the study.<br><br><b>ENDING THE STUDY<\/b><br>At the end of the study, you will be shown debriefing information and instructions for receiving SONA credit. Your responses will be recorded under a random participation code rather than your name. <br><br><b>IF I WANT TO STOP PARTICIPATING IN THIS STUDY, WHAT SHOULD I DO?<\/b><br>You are free to leave the study at any time, without penalty. If you share your reasons, they may become part of our record. The researchers <b>will <\/b>keep the information collected about you for the research <b>unless you ask us<\/b> to delete <b>it from our records<\/b>. If the researchers <b>have already<\/b> used your information in a research analysis it will not be possible to remove your information. To leave the study, click out of the browser tab.<br><br><b>HOW WILL THE RESEARCHERS PROTECT MY INFORMATION?\n<\/b><br>Your name will not be used in conjunction with your responses. SONA provides a random participation code that is used only for crediting purposes. Your de-identified research data may be used in research reports, articles, or presentations, but will not include information that would let others know who you are. De-identified data may be shared for future research. <br><br><b>CONTACT INFORMATION\n<\/b><br>Questions, concerns, or the wish to leave a study should be directed to:<br><b>Study Creator:<\/b> Gregory Stanley; Phone: (714) 454-0435; Email: gregstan@umich.edu, <br><b>Faculty Advisor:<\/b> Jun Zhang; Phone: (734) 763-6161; Email: junz@umich.edu <br><br>To express concern about a study, contact University of Michigan Health Sciences and Behavioral Sciences Institutional Review Board, 2800 Plymouth Road, Building 520, Room 1169 Ann Arbor, MI 48109. Call: 734-936-0933 or toll free 866-936-0933; Fax: 734-936-1852; E-mail: irbhsbs@umich.edu. You can also contact the University of Michigan Compliance Hotline at (866) 990-0111.\n<br>The University of Michigan Institutional Review Board Health Sciences and Behavioral Sciences has determined that this platform is exempt from IRB oversight, but individual researchers must submit proof of IRB approval before deploying experiments. <br><br>YOUR CONSENT\n<br>I understand that my participation in the studies described above is entirely voluntary, and I hereby agree to be a participant on this platform.","DefaultChoices":false,"DataExportTag":"Consent Form","QuestionID":"QID1","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"UNIVERSITY OF MICHIGAN CONSENT TO BE PART OF THIS STUDY Study Title: Moral Judgments Study Creato...","Choices":{"1":{"Display":"I CONSENT to participate in this study"},"2":{"Display":"I DO NOT consent to participant in this study"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID10","SecondaryAttribute":"What is your race?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your race?<br>","DefaultChoices":false,"DataExportTag":"Race","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","Autoscale":{"YScale":{"Name":"race","Type":"likert","Reverse":false}}},"QuestionDescription":"What is your race?","Choices":{"1":{"Display":"White"},"2":{"Display":"Black or African American"},"3":{"Display":"American Indian or Alaska Native"},"4":{"Display":"Asian"},"5":{"Display":"Native Hawaiian or Pacific Islander"},"6":{"Display":"Other"},"7":{"Display":"Self describe","TextEntry":"true"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID10"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID100","SecondaryAttribute":"Think back to the two versions of the story where Clark sold an explosive charge to Bill who (1)...","TertiaryAttribute":null,"Payload":{"QuestionText":"Think back to the two versions of the story where Clark sold an explosive charge to Bill who (1) was a <i>mentally competent<\/i> adult and (2) had a <i>brain injury<\/i> that prevented him from <i>controlling<\/i> and <i>understanding<\/i> the consequences of his actions.<br>In which version of the story do you consider Clark to be more morally blameworthy for the harm that occurred?<br>","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Think back to the two versions of the story where Clark sold an explosive charge to Bill who (1)...","Choices":{"1":{"Display":"Clark is more blameworthy in the story where Bill is a mentally competent adult."},"2":{"Display":"Clark is more blameworthy in the story where Bill has brain damage."}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionText_Unsafe":"Think back to the version of the story where Ultimo sold explosive chemicals and Proximo triggered the explosion.<br>In that version of the story, who do you think is more morally blameworthy for the harm that occurred?<br>","DataExportTag":"2afc_p_intraperson_1","QuestionID":"QID100"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID101","SecondaryAttribute":"Again, think back to the two versions of the story where Clark sold an explosive charge to Bill w...","TertiaryAttribute":null,"Payload":{"QuestionText":"Again, think back to the two versions of the story where Clark sold an explosive charge to Bill who (1) was a <i>mentally competent<\/i> adult and (2) had a <i>brain injury<\/i> that prevented him from <i>controlling<\/i> and <i>understanding<\/i> the consequences of his actions.<br>Please select one of the following:<br>","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Again, think back to the two versions of the story where Clark sold an explosive charge to Bill w...","Choices":{"1":{"Display":"I actually think that Clark is roughly equally morally blameworthy in both stories."},"2":{"Display":"Indeed, I think that Clark is more morally blameworthy in one story than in the other story."}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionText_Unsafe":"Again, think back to the version of the story where Ultimo sold explosive chemicals and Proximo triggered the explosion.<br>Please select one of the following:<br>","DataExportTag":"2afc_p_intraperson_2","QuestionID":"QID101"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID102","SecondaryAttribute":"Think back to the version of the story where Clark flipped the first switch, redirecting the trol...","TertiaryAttribute":null,"Payload":{"QuestionText":"Think back to the version of the story where Clark flipped the first switch, redirecting the trolley towards Bill's fork, and then Bill flipped the second switch, redirecting the trolley towards the workman.\n<br>Who do you think is more morally blameworthy for the harm that occurred?<br>","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Think back to the version of the story where Clark flipped the first switch, redirecting the trol...","Choices":{"1":{"Display":"Clark (the operator at the first fork) is more blameworthy."},"2":{"Display":"Bill (the operator at the second fork) is more blameworthy."}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionText_Unsafe":"Think back to the two versions of the story where Ultimo sold explosive chemicals to Proximo who (1) was a mentally competent adult and (2) had a problem with his brain that prevented him from controlling and understanding the consequences of his actions.<br>In which version of the story do you consider Ultimo to be more morally blameworthy for the harm that occurred?<br>","DataExportTag":"2afc_t_interperson_1","QuestionID":"QID102"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID103","SecondaryAttribute":"Again, think back to the version of the story where Clark flipped the first switch, redirecting t...","TertiaryAttribute":null,"Payload":{"QuestionText":"Again, think back to the version of the story where Clark flipped the first switch, redirecting the trolley towards Bill's fork, and then Bill flipped the second switch, redirecting the trolley towards the workman.<br>Please select one of the following:","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Again, think back to the version of the story where Clark flipped the first switch, redirecting t...","Choices":{"1":{"Display":"I actually think that both Clark and Bill are roughly equally morally blameworthy."},"2":{"Display":"Indeed, I think that one of these characters is more morally blameworthy than the other."}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionText_Unsafe":"Again, think back to the two versions of the story where Ultimo sold explosive chemicals to Proximo who (1) was a mentally competent adult and (2) had a problem with his brain that prevented him from controlling and understanding the consequences of his actions.<br>Please select one of the following:<br>","DataExportTag":"2afc_t_interperson_2","QuestionID":"QID103"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID104","SecondaryAttribute":"Think back to the two versions of the story where Clark flipped the switch, redirecting the troll...","TertiaryAttribute":null,"Payload":{"QuestionText":"Think back to the two versions of the story where Clark flipped the switch, redirecting the trolley towards the second fork which was operated by (1) <i>Bill, another operator<\/i> and (2) a <i>computerized switching mechanism<\/i>.&nbsp;<br>In which version of the story do you consider Clark to be more morally blameworthy for the harm that occurred?<br>","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Think back to the two versions of the story where Clark flipped the switch, redirecting the troll...","Choices":{"1":{"Display":"Clark is more blameworthy in the story where the second fork is operated by Bill, another operator."},"2":{"Display":"Clark is more blameworthy in the story where the second fork is operated by a computerized switching mechanism."}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionText_Unsafe":"Think back to the two versions of the story where Ultimo sold explosive chemicals to Proximo who (1) was a mentally competent adult and (2) had a problem with his brain that prevented him from controlling and understanding the consequences of his actions.<br>In which version of the story do you consider Ultimo to be more morally blameworthy for the harm that occurred?<br>","DataExportTag":"2afc_t_intraperson_1","QuestionID":"QID104"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID105","SecondaryAttribute":"Again, think back to the two versions of the story where Clark flipped the switch, redirecting th...","TertiaryAttribute":null,"Payload":{"QuestionText":"Again, think back to the two versions of the story where Clark flipped the switch, redirecting the trolley towards the second fork which was operated by (1) <i>Bill, another operator<\/i> and (2) a <i>computerized switching mechanism<\/i>. <br>Please select one of the following:<br>","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Again, think back to the two versions of the story where Clark flipped the switch, redirecting th...","Choices":{"1":{"Display":"I actually think that Clark is roughly equally morally blameworthy in both stories."},"2":{"Display":"Indeed, I think that Clark is more morally blameworthy in one story than in the other story."}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"QuestionText_Unsafe":"Again, think back to the two versions of the story where Ultimo sold explosive chemicals to Proximo who (1) was a mentally competent adult and (2) had a problem with his brain that prevented him from controlling and understanding the consequences of his actions.<br>Please select one of the following:<br>","DataExportTag":"2afc_t_intraperson_2","QuestionID":"QID105"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID106","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q102","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID106"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID107","SecondaryAttribute":"Do you have any feedback about your experience participating in this experiment, such as aspects...","TertiaryAttribute":null,"Payload":{"QuestionText":"Do you have any feedback about your experience participating in this experiment, such as aspects that were confusing or irritating about the user-interface? Your feedback can help improve the experiment for future participants.&nbsp;","DefaultChoices":false,"DataExportTag":"user_feedback","QuestionType":"TE","Selector":"ESTB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Do you have any feedback about your experience participating in this experiment, such as aspects...","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None","MinChars":"1"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID107"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID108","SecondaryAttribute":"DEBRIEFING FORM FOR RESPONSIBILITY SHIELDING PARTICIPANTS Study Title: Moral Judgments Study Crea...","TertiaryAttribute":null,"Payload":{"QuestionText":"<b>DEBRIEFING FORM FOR RESPONSIBILITY SHIELDING PARTICIPANTS<\/b><br><br><b>Study Title:<\/b> Moral Judgments<br><b>Study Creator:<\/b> Gregory Stanley, Ph.D. Candidate, University of Michigan<br><br>Thank you for participating in this study. Your time and effort contribute greatly to research on moral judgment and responsibility. Please read this debriefing form to understand the purpose and design of the study you took part in.\n<br><br><b>PURPOSE OF THIS STUDY\n<\/b><br>This study investigates how people assign responsibility, wrongness, and punishment in scenarios where harm results from multiple steps in a causal chain. The study examines how features of the causal structure (for example, whether the final harmful outcome depends on another person\u2019s deliberate choice versus a non-agentic process) influence moral judgments.\n<br><br><b>CONTACT INFORMATION\n<\/b><br>Should you have any questions or concerns related to this study, please contact:\n<br>\u2022\t<b>Platform Creator:<\/b> Gregory Stanley; Phone: (714) 454-0435; Email: gregstan@umich.edu\n<br>\u2022\t<b>Faculty Advisor:<\/b> Jun Zhang; Phone: (734) 763-6161; Email: junz@umich.edu\n<br>\u2022\tIf you have questions about your rights as a research participant, or wish to obtain information, ask questions or discuss any concerns about this study with someone other than the researcher(s), please contact the University of Michigan Health Sciences and Behavioral Sciences Institutional Review Board (IRB-HSBS), 2800 Plymouth Rd., Building 520, Room 1169, Ann Arbor, MI 48109-2800, Phone: 734-936-0933, Fax: 734-936-1852, Email: irbhsbs@umich.edu.\n<br><br><b>THANK YOU!\n<\/b><br>We truly appreciate your time and cooperation in participating in this study. Your contribution plays a vital role in enhancing our understanding of human cooperation and behavior. We look forward to your future participation and thank you once again for being part of this valuable research effort.\n<br>\u2022\tCramer (2000). Behavioral Game Theory: Experiments in Strategic Interaction. Princeton, NJ: Princeton University Press.\n<br>\u2022\tRabin (1993). Understanding social preferences with simple tests. The American Economic Review, 83(5), 1281-1302.<br><br><b>Click NEXT to be credited!<\/b><br>","DefaultChoices":false,"DataExportTag":"debriefing","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"DEBRIEFING FORM FOR RESPONSIBILITY SHIELDING PARTICIPANTS Study Title: Moral Judgments Study Crea...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID108"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID109","SecondaryAttribute":"Think back to the two versions of the story where Clark flipped the switch (1) before Bill versus...","TertiaryAttribute":null,"Payload":{"QuestionText":"Think back to the two versions of the story where Clark flipped the switch (1) <i>before<\/i> Bill versus (2) <i>at the same time<\/i> as Bill. \nIn which version of the story do you consider Clark to be more morally blameworthy for the harm that occurred?","DefaultChoices":false,"DataExportTag":"2afc_t_intraperson_3","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Think back to the two versions of the story where Clark flipped the switch (1) before Bill versus...","Choices":{"1":{"Display":"Clark is more blameworthy in the story where he flips the switch before Bill."},"2":{"Display":"Clark is more blameworthy in the story where he flips the switch at the same time as Bill."}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID109"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID11","SecondaryAttribute":"How would you describe your political orientation?","TertiaryAttribute":null,"Payload":{"QuestionText":"How would you describe your political orientation?","DefaultChoices":false,"DataExportTag":"Political","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How would you describe your political orientation?","Choices":{"1":{"Display":"Liberal\/progressive"},"2":{"Display":"Conservative"},"3":{"Display":"Libertarian\/classical liberal"},"4":{"Display":"Moderate"},"5":{"Display":"Nonpolitical"},"6":{"Display":"Self describe","TextEntry":"true"}},"ChoiceOrder":[1,2,3,4,5,6],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":1,"QuestionID":"QID11"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID110","SecondaryAttribute":"Again, think back to the two versions of the story where Clark flipped the switch (1) before Bill...","TertiaryAttribute":null,"Payload":{"QuestionText":"Again, think back to the two versions of the story where Clark flipped the switch (1) <i>before<\/i> Bill versus (2) <i>at the same time<\/i> as Bill.<br>Please select one of the following:<br>","DefaultChoices":false,"DataExportTag":"2afc_t_intraperson_4","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Again, think back to the two versions of the story where Clark flipped the switch (1) before Bill...","Choices":{"1":{"Display":"I actually think Clark is roughly equally morally blameworthy in both stories."},"2":{"Display":"Indeed, I think that Clark is more morally blameworthy in one story than in the other."}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID110"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID111","SecondaryAttribute":"Think back to the two versions of the story where (1) Clark armed the flare canister before selli...","TertiaryAttribute":null,"Payload":{"QuestionText":"Think back to the two versions of the story where (1) Clark armed the flare canister <i>before<\/i> selling it to Bill versus (2) Clark armed the flare canister remotely <i>at the same time<\/i> that Bill ignited it.&nbsp;<br>In which version of the story do you consider Clark to be more morally blameworthy for the harm that occurred?<br>","DefaultChoices":false,"DataExportTag":"2afc_p_intraperson_3","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Think back to the two versions of the story where (1) Clark armed the flare canister before selli...","Choices":{"1":{"Display":"Clark is more blameworthy in the story where he armed the flare canister before selling it to Bill."},"2":{"Display":"Clark is more blameworthy in the story where he armed the flare canister remotely at the same time that Bill ignited it."}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID111"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID112","SecondaryAttribute":"Again, think back to the two versions of the story where (1) Clark armed the flare canister befor...","TertiaryAttribute":null,"Payload":{"QuestionText":"Again, think back to the two versions of the story where (1) Clark armed the flare canister <i>before<\/i> selling it to Bill versus (2) Clark armed the flare canister remotely <i>at the same time<\/i> that Bill ignited it. <br>Please select one of the following:<br>","DefaultChoices":false,"DataExportTag":"2afc_p_intraperson_4","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Again, think back to the two versions of the story where (1) Clark armed the flare canister befor...","Choices":{"1":{"Display":"I actually think that Clark is roughly equally morally blameworthy in both stories."},"2":{"Display":"Indeed, I think that Clark is more morally blameworthy in one story than in the other story."}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID112"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID12","SecondaryAttribute":"Please read the following scenario carefully. At 7:20 PM, the people of the small town of Masonvi...","TertiaryAttribute":null,"Payload":{"QuestionText":"<img src=\"https:\/\/umich.qualtrics.com\/CP\/Graphic.php?IM=IM_3nnGNLECkyAB6A0\" style=\"width: 435px; height: 390px;\"><br>\nPlease read the following scenario carefully.<br>\n<br>\nAt 7:20 PM, the people of the small town of Masonville crowd into the open-air high school football stadium seats, excited for the fireworks finale scheduled for after 8:00 PM. The town is offering a $2,000 cash prize automatically awarded to whoever produces the highest-intensity fireworks display over the stadium, measured by sensors pointing toward the sky. A resident of Masonville, Bill thinks of a plan to win the prize and walks up the hill to buy chemicals from a specialty supply store\u2014the only such store within 300 miles.<br>\n&nbsp;<br>\nIn the store, Bill walks over to Clark the clerk and says, \u201cI\u2019d like to buy a high-intensity pyrotechnic flare canister.\u201d<br>\n<br>\n\u201cPlanning to light off some fireworks?\u201d Clark askes.<br>\n<br>\n\u201cThat\u2019s right.\u201d<br>\n<br>\n\u201cThat\u2019s an unusually powerful canister,\u201d Clark says. \u201cIf it goes off over the stadium, people are definitely going to get hurt.\u201d<br>\n<br>\n\u201cI know,\u201d Bill says. \u201cBut it\u2019s the only way to win the $2,000 prize.\u201d<br>\n<br>\n\u201cPlease face the camera,\u201d Clark says. \u201cOur AI system needs to run a background and safety check based on subtle behaviors and your request.\u201d<br>\n<br>\nThe monitor displays <i>nothing abnormal in Bill\u2019s background<\/i> but displays a warning: \u201cIf these chemicals are activated, there is a 75% chance that Bill will ignite them over the stadium. If he ignites them over the stadium, nearby viewers will be injured.\u201d Clark has learned to trust the system\u2019s accuracy.<br>\n<br>\nStore policy prohibits Clark from refusing the sale, but he is not obligated to arm the canister. However, arming the canister triggers his commission: Clark will only get paid $2,000 in commission if he arms the canister and he really wants the money. Despite fearing what Bill will do, Clark carefully carries over the flare canister and attaches the fuse. Bill sees him do it. Clark completes the sale. Clark cannot reach anyone who could clear the stadium in time.<br>\n<br>\nAfter 8:00 PM, Bill ignites the canister over the stadium. One spectator nearby is burned and needs medical treatment, but fully recovers.","DefaultChoices":false,"DataExportTag":"pucc_vignette","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please read the following scenario carefully. At 7:20 PM, the people of the small town of Masonvi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID12"}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID15","SecondaryAttribute":"Please rate how morally wrong you consider Clark's (the clerk) action to be from (1) not morally...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please rate how morally wrong you consider Clark's (the clerk) action to be from (1) not morally wrong at all to (9) extremely morally wrong.<br>Here, \"moral wrongness\" means how morally wrong the action itself was, regardless of what happened later, where the \"action\" refers to Clark's choice to sell Bill the explosive chemicals.&nbsp;<br>","DefaultChoices":false,"DataExportTag":"pucc_wrong","QuestionID":"QID15","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"ChoiceColumnWidthPixels":117},"QuestionDescription":"Please rate how morally wrong you consider Clark's (the clerk) action to be from (1) not morally...","Choices":{"1":{"Display":"wrongness"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":10,"Answers":{"1":{"Display":"(1) Not wrong at all"},"2":{"Display":"2"},"3":{"Display":"3"},"4":{"Display":"4"},"5":{"Display":"5"},"6":{"Display":"6"},"7":{"Display":"7"},"8":{"Display":"8"},"9":{"Display":"(9) Extremely wrong"}},"AnswerOrder":[1,2,3,4,5,6,7,"8","9"],"ChoiceDataExportTags":false}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID16","SecondaryAttribute":"Imagine you are a judge deciding on a prison sentence for Clark (the clerk) based on this story a...","TertiaryAttribute":null,"Payload":{"QuestionText":"Imagine you are a judge deciding on a prison sentence for Clark (the clerk) based on this story alone.<br>How many years in prison should Clark receive? Please enter a whole number between 0 and 50.<br>","DefaultChoices":false,"DataExportTag":"pucc_punish","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","InputWidth":115,"InputHeight":29},"QuestionDescription":"Imagine you are a judge deciding on a prison sentence for Clark (the clerk) based on this story a...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":"1","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"0","Max":"50","NumDecimals":"0"}}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID16","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"]}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID19","SecondaryAttribute":"Please rate how morally blameworthy you consider Clark (the clerk) to be from (1) not morally bla...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please rate how morally blameworthy you consider Clark (the clerk) to be from (1) not morally blameworthy at all to (9) extremely morally blameworthy.\nHere, \"moral blameworthiness\" means how much you think Clark deserves to be blamed or held responsible for the harm that occurred in the story.","DefaultChoices":false,"DataExportTag":"pucc_blame","QuestionID":"QID19","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"ChoiceColumnWidthPixels":115},"QuestionDescription":"Please rate how morally blameworthy you consider Clark (the clerk) to be from (1) not morally bla...","Choices":{"1":{"Display":"blameworthiness"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":10,"Answers":{"1":{"Display":"(1) Not blameworthy at all"},"2":{"Display":"2"},"3":{"Display":"3"},"4":{"Display":"4"},"5":{"Display":"5"},"6":{"Display":"6"},"7":{"Display":"7"},"8":{"Display":"8"},"9":{"Display":"(9) Extremely blameworthy"}},"AnswerOrder":[1,2,3,4,5,6,7,"8","9"],"ChoiceDataExportTags":false}},{"SurveyID":"SV_1R04UaiYX3Qqp1A","Element":"SQ","PrimaryAttribute":"QID2","SecondaryAttribute":"Welcome Thank you for participating in this study. In this study, you will read several short sce...","TertiaryAttribute":null,"Payload":{"QuestionText":"Welcome\n<br><br>Thank you for participating in this study. In this study, you will read several short scenarios and make judgments about the people involved. You will then complete a few brief questionnaires.\n\nThe study takes approximately 20-30 minutes.\nAll responses are anonymous. You may withdraw at any time without penalty.&nbsp;<br><br>Once you read the debriefing form at the
# Copy this file to .env and fill in your API keys.
# .env is in .gitignore and will never be committed to git.

# Anthropic (Claude) — console.anthropic.com → API keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o etc.) — platform.openai.com → API keys
OPENAI_API_KEY=sk-proj-...

# Google (Gemini) — aistudio.google.com → Get API key (has a free tier)
GOOGLE_API_KEY=AIza...

# xAI (Grok) — console.x.ai → API keys (new accounts get $25 free)
XAI_API_KEY=xai-...

# DeepSeek — platform.deepseek.com → API keys (~$0.14/1M tokens, very cheap)
DEEPSEEK_API_KEY=sk-...

# Ollama runs locally on your machine — no key needed
# Install from ollama.com, then: ollama pull mistral
